[Unit]
Description=Monitor Noturno para Idoso
After=network.target

[Service]
Type=simple
User=monitor
WorkingDirectory=/home/monitor/elderly-monitor
ExecStart=/home/monitor/elderly-monitor/venv/bin/python main.py
Restart=on-failure
RestartSec=10
StandardOutput=append:/home/monitor/elderly-monitor/monitor.log
StandardError=append:/home/monitor/elderly-monitor/monitor.log
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
